// ============================================================================
// RefreshToken - for JWT refresh token management
// ============================================================================
model RefreshToken {
  id          String   @id @default(cuid())
  publisherId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revoked     Boolean  @default(false)

  // Relations
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@index([publisherId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// OAuthState - stores PKCE code_verifier during OAuth flow
// ============================================================================
model OAuthState {
  id             String   @id @default(cuid())
  state          String   @unique
  codeChallenge  String   // CLI's code challenge (SHA256 of verifier)
  redirectUri    String
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([state])
  @@index([expiresAt])
  @@map("oauth_states")
}

// ============================================================================
// OneTimeCode - temporary code exchanged for JWT tokens
// ============================================================================
model OneTimeCode {
  id          String   @id @default(cuid())
  code        String   @unique
  publisherId String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  used        Boolean  @default(false)

  // Relations
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([expiresAt])
  @@map("one_time_codes")
}
