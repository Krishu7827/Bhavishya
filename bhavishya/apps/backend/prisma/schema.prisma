// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Publisher - represents a model publisher who authenticates via Google OAuth
// ============================================================================
model Publisher {
  id        String   @id @default(cuid())
  googleId  String   @unique
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  models          Model[]
  sessions        Session[]
  refreshTokens   RefreshToken[]
  oneTimeCodes    OneTimeCode[]

  @@index([googleId])
  @@index([email])
  @@map("publishers")
}

// ============================================================================
// Model - represents a published AI model endpoint
// ============================================================================
model Model {
  id             String   @id @default(cuid())
  publisherId    String
  name           String
  description    String
  baseUrl        String
  encryptedApiKey String // AES-256-GCM encrypted, never returned in API responses
  tags           String[]
  contextWindow  Int
  pricingNotes   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([publisherId])
  @@index([tags])
  @@map("models")
}

// ============================================================================
// Session - represents a short-lived gateway session for end users
// ============================================================================
model Session {
  id         String   @id @default(cuid())
  publisherId String?
  modelId    String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  // Relations
  publisher Publisher? @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  model     Model      @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([publisherId])
  @@index([modelId])
  @@index([expiresAt])
  @@map("sessions")
}

