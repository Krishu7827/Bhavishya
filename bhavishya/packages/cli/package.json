{
  "name": "@future/cli",
  "version": "1.0.0",
  "description": "Future CLI - Model marketplace client",
  "author": "Future Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/future/model-marketplace",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "ai",
    "model-marketplace",
    "anthropic",
    "claude",
    "openai"
  ],
  "bin": {
    "future": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@future/shared": "*",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
