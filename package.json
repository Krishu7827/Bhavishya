{
  "name": "agentmarket",
  "version": "0.2.0",
  "description": "A CLI package that gives Claude Code a marketplace superpower",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "agentmarket": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node test-specialties.js",
    "test:all": "npm run test && node test-supabase.js && node test-coinbase.js"
  },
  "keywords": [
    "ai",
    "claude",
    "mcp",
    "agents",
    "marketplace",
    "cli"
  ],
  "author": "Adarsh",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@coinbase/coinbase-sdk": "^0.10.0",
    "@supabase/supabase-js": "^2.39.3",
    "@anthropic-ai/sdk": "^0.32.1",
    "express": "^4.18.2",
    "zod": "^3.22.4",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "tsx": "^4.7.0"
  }
}
